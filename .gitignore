# Artefatos de build
build/
*.o
*.obj
*.elf
*.bin
*.out

# Listagens e mapas (NASM / ld)
*.lst
*.map

# Scratch de captura PPM dos testes/demos (a referência golden é versionada à parte)
out.ppm

# Debug / core dumps
*.dSYM/
core
core.*
vgcore.*
# but NOT the include/core/ source dir (libcore.a public surface, ADR-0009) --
# the bare `core` pattern above would otherwise swallow it
!include/core/
!include/core/**
# nor glintfx/vendor/core/ (L1.20-FONTFLIP Phase 1 vendored copy of Layer 0's font-engine
# "meat" -- glintfx/vendor/core/README.md) -- same trap, same fix
!glintfx/vendor/core/
!glintfx/vendor/core/**

# Editores / IDE
*~
*.swp
.vscode/
.idea/

# Sistema operacional
.DS_Store

# Repos upstream clonados para estudo/RE (licenças próprias: RmlUi=MIT, gl3w=public domain)
# Não versionar no nosso repo (MPL-2.0) para evitar mistura de licença e inchaço.
/examples/

# scratch do subagent-driven-development (em qualquer profundidade)
.superpowers/
**/.superpowers/

# Build dirs locais que espelham nomes usados pelos workflows de CI/local
# validation (ci.yml: build-ON/build-OFF/build-lint; nightly.yml, TST-L1-MEM:
# build-asan/build-asan-off/build-asan-ON/build-asan-OFF) -- "build/" acima só
# casa o nome exato "build", não esses sufixados.
glintfx/build-*/
