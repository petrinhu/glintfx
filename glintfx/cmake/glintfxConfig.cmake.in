# SPDX-License-Identifier: MPL-2.0
# EN: CMake package config for find_package(glintfx).
#     Generated from cmake/glintfxConfig.cmake.in — do not edit the installed copy.
#
#     Strategy: rmlui_core is co-installed under <libdir>/glintfx/ (private subdir)
#     because CMake 4.x forbids install(EXPORT) when PRIVATE transitive deps are not
#     in an export set, and rmlui_core is a FetchContent/vendored target that cannot
#     be installed as a proper exported CMake target alongside glintfx.
#     gl3w is an INTERFACE library whose single source (gl3w.c) is compiled directly
#     into libglintfx.a — no separate archive needed.
#
#     GLFW backend propagation: @GLINTFX_BACKEND_GLFW@ is substituted at configure time
#     with ON or OFF. When OFF, find_dependency(glfw3) is NOT called and glfw is NOT
#     included in INTERFACE_LINK_LIBRARIES — embed-only consumers are not forced to have
#     GLFW installed.
#
# PT: Config de pacote CMake para find_package(glintfx).
#     Gerado de cmake/glintfxConfig.cmake.in — não edite a cópia instalada.
#
#     Estratégia: rmlui_core é co-instalado em <libdir>/glintfx/ (subdiretório privado)
#     porque o CMake 4.x proíbe install(EXPORT) quando deps transitivas PRIVATE não
#     estão em um export set, e rmlui_core é um target FetchContent/vendorizado que
#     não pode ser instalado como target CMake exportado junto com glintfx.
#     gl3w é uma biblioteca INTERFACE cujo único fonte (gl3w.c) é compilado diretamente
#     em libglintfx.a — nenhum arquivo separado é necessário.
#
#     Propagação do backend GLFW: @GLINTFX_BACKEND_GLFW@ é substituído em configure time
#     com ON ou OFF. Quando OFF, find_dependency(glfw3) NÃO é chamado e glfw NÃO é
#     incluído em INTERFACE_LINK_LIBRARIES — consumidores embed-only não são forçados a
#     ter GLFW instalado.

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# EN: Embed the GLFW-backend flag baked at build time.
#     This variable is ON or OFF depending on how glintfx was built.
# PT: Embarca a flag do backend GLFW fixada em build time.
#     Esta variável é ON ou OFF dependendo de como o glintfx foi compilado.
set(_glintfx_glfw_backend @GLINTFX_BACKEND_GLFW@)

# EN: System-level dependencies. OpenGL and FreeType are always required.
#     glfw3 is only required when the library was built with the GLFW window backend.
# PT: Dependências de sistema. OpenGL e FreeType são sempre exigidos.
#     glfw3 só é exigido quando a lib foi compilada com o backend de janela GLFW.
find_dependency(OpenGL REQUIRED)
find_dependency(Freetype REQUIRED)
if(_glintfx_glfw_backend)
  find_dependency(glfw3 REQUIRED)
endif()

if(NOT TARGET glintfx::glintfx)
  # EN: Resolve install-tree paths (set_and_check verifies the path exists).
  #     @PACKAGE_CMAKE_INSTALL_LIBDIR@ / @PACKAGE_CMAKE_INSTALL_INCLUDEDIR@ are
  #     computed by configure_package_config_file relative to the prefix.
  # PT: Resolve os paths da árvore de install (set_and_check verifica que o path existe).
  #     @PACKAGE_CMAKE_INSTALL_LIBDIR@ / @PACKAGE_CMAKE_INSTALL_INCLUDEDIR@ são
  #     calculados por configure_package_config_file relativos ao prefixo.
  set_and_check(_glintfx_lib_dir  "@PACKAGE_CMAKE_INSTALL_LIBDIR@")
  set_and_check(_glintfx_inc_dir  "@PACKAGE_CMAKE_INSTALL_INCLUDEDIR@")

  # EN: Main static archive (glintfx proper + gl3w.c objects compiled in).
  # PT: Arquivo estático principal (glintfx + objetos de gl3w.c compilados dentro).
  find_library(_glintfx_archive
    NAMES glintfx
    PATHS "${_glintfx_lib_dir}"
    NO_DEFAULT_PATH REQUIRED)

  # EN: Co-installed RmlUi core archive. Lives under <libdir>/glintfx/ so it does
  #     not conflict with a system- or consumer-installed RmlUi. The consumer does
  #     not need RmlUi headers — glintfx's public API is opaque.
  # PT: Arquivo rmlui_core co-instalado. Fica em <libdir>/glintfx/ para não conflitar
  #     com um RmlUi instalado no sistema ou pelo consumidor. O consumidor não precisa
  #     dos headers do RmlUi — a API pública do glintfx é opaca.
  find_library(_glintfx_rmlui_archive
    NAMES rmlui
    PATHS "${_glintfx_lib_dir}/glintfx"
    NO_DEFAULT_PATH REQUIRED)

  # EN: Build the INTERFACE_LINK_LIBRARIES list: rmlui (co-installed) + OpenGL + FreeType
  #     + glfw only when the GLFW backend is enabled. This ensures embed-only consumers
  #     do not pull in glfw as a transitive dependency when it was not compiled in.
  # PT: Monta a lista INTERFACE_LINK_LIBRARIES: rmlui (co-instalado) + OpenGL + FreeType
  #     + glfw só quando o backend GLFW está habilitado. Isso garante que consumidores
  #     embed-only não puxem glfw como dep transitiva quando não foi compilado na lib.
  if(_glintfx_glfw_backend)
    set(_glintfx_iface_libs
      "${_glintfx_rmlui_archive};OpenGL::GL;glfw;Freetype::Freetype")
  else()
    set(_glintfx_iface_libs
      "${_glintfx_rmlui_archive};OpenGL::GL;Freetype::Freetype")
  endif()

  add_library(glintfx::glintfx STATIC IMPORTED)
  set_target_properties(glintfx::glintfx PROPERTIES
    IMPORTED_LOCATION             "${_glintfx_archive}"
    INTERFACE_COMPILE_FEATURES    "cxx_std_17"
    INTERFACE_INCLUDE_DIRECTORIES "${_glintfx_inc_dir}"
    # EN: INTERFACE_LINK_LIBRARIES: rmlui archive (private, co-installed) +
    #     system libs (OpenGL, FreeType, and optionally GLFW).
    # PT: INTERFACE_LINK_LIBRARIES: arquivo rmlui (privado, co-instalado) +
    #     libs de sistema (OpenGL, FreeType, e opcionalmente GLFW).
    INTERFACE_LINK_LIBRARIES      "${_glintfx_iface_libs}"
  )

  # EN: find_library() writes _glintfx_archive / _glintfx_rmlui_archive into CACHE
  #     (it always caches its result variable). unset() without CACHE only clears the
  #     local/normal-variable shadow, leaving the cache entry behind — harmless here
  #     because the whole block is guarded by if(NOT TARGET glintfx::glintfx), but
  #     semantically wrong: a stale cache entry could resolve to a wrong path if the
  #     install tree moves between two find_package() calls in the same build tree.
  #     unset(... CACHE) removes the cache entry too, matching the non-caching temp
  #     variables above (_glintfx_lib_dir / _glintfx_inc_dir / _glintfx_iface_libs,
  #     which were never cached, so plain unset() remains correct for those).
  # PT: find_library() grava _glintfx_archive / _glintfx_rmlui_archive no CACHE (ele
  #     sempre cacheia sua variável de resultado). unset() sem CACHE só limpa a sombra
  #     local/normal, deixando a entrada de cache para trás — inofensivo aqui porque
  #     o bloco inteiro é protegido por if(NOT TARGET glintfx::glintfx), mas
  #     semanticamente errado: uma entrada de cache obsoleta poderia resolver para um
  #     path errado se a árvore de instalação mudar entre duas chamadas de
  #     find_package() na mesma árvore de build. unset(... CACHE) remove a entrada de
  #     cache também, alinhando com as variáveis temporárias não cacheadas acima
  #     (_glintfx_lib_dir / _glintfx_inc_dir / _glintfx_iface_libs, que nunca foram
  #     cacheadas, então o unset() simples permanece correto para elas).
  unset(_glintfx_lib_dir)
  unset(_glintfx_inc_dir)
  unset(_glintfx_archive CACHE)
  unset(_glintfx_rmlui_archive CACHE)
  unset(_glintfx_iface_libs)
endif()

unset(_glintfx_glfw_backend)

check_required_components(glintfx)
