// EN: 1  when the GLFW window backend is compiled in: glintfx::App is available.
//     0  in embed-only builds: only glintfx::UiLayer is available; no glintfx::App.
//     Use this macro to guard code that depends on the standalone App facade.
//     Example:
//       #if GLINTFX_BACKEND_GLFW
//         glintfx::App app({ .title = "hello", .width = 800, .height = 600 });
//       #endif
// PT: 1  quando o backend de janela GLFW está compilado: glintfx::App está disponível.
//     0  em builds embed-only: apenas glintfx::UiLayer disponível; sem glintfx::App.
//     Use esta macro para guardar código que depende da fachada App standalone.
#cmakedefine01 GLINTFX_BACKEND_GLFW

