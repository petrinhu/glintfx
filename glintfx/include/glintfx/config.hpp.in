#pragma once

// EN: 1  when the GLFW window backend is compiled in: glintfx::App is available.
//     0  in embed-only builds: only glintfx::UiLayer is available; no glintfx::App.
//     Use this macro to guard code that depends on the standalone App facade.
//     Example:
//       #if GLINTFX_BACKEND_GLFW
//         glintfx::App app({ .title = "hello", .width = 800, .height = 600 });
//       #endif
// PT: 1  quando o backend de janela GLFW está compilado: glintfx::App está disponível.
//     0  em builds embed-only: apenas glintfx::UiLayer disponível; sem glintfx::App.
//     Use esta macro para guardar código que depende da fachada App standalone.
#cmakedefine01 GLINTFX_BACKEND_GLFW

// EN: 1  (default since L1.20-FONTFLIP Phase 1) when glintfx's own SOV-SFNT/SOV-RAST/SOV-HINT
//        font engine (L1.19-FONTENG) is compiled in (sources vendored under
//        glintfx/vendor/core/, see its README.md) and installed via
//        Rml::SetFontEngineInterface() BEFORE Rml::Initialise() -- see
//        glintfx/CMakeLists.txt's GLINTFX_OWN_FONT_ENGINE option and src/bootstrap.cpp's
//        Bootstrap::init(). RmlUi's own RMLUI_FONT_ENGINE=freetype build option is left
//        untouched either way (CMakeLists.txt) -- this is a RUNTIME A/B switch, not a
//        RmlUi-rebuild switch; FreeType stays linked and available regardless of this macro
//        ("soft flip", not a drop).
//     0  RmlUi's own FreeType-backed default font engine is used, unchanged (set only when a
//        consumer explicitly configures -DGLINTFX_OWN_FONT_ENGINE=OFF).
// PT: 1  (padrão desde o L1.20-FONTFLIP Fase 1) quando o motor de fonte próprio do glintfx
//        (SOV-SFNT/SOV-RAST/SOV-HINT, L1.19-FONTENG) é compilado (sources vendorizados em
//        glintfx/vendor/core/, ver o README.md dele) e instalado via
//        Rml::SetFontEngineInterface() ANTES do Rml::Initialise() -- ver a option
//        GLINTFX_OWN_FONT_ENGINE do glintfx/CMakeLists.txt e o Bootstrap::init() do
//        src/bootstrap.cpp. A option de build RMLUI_FONT_ENGINE=freetype do próprio RmlUi
//        permanece intocada de qualquer forma (CMakeLists.txt) -- isto é uma chave A/B de
//        RUNTIME, não uma chave de rebuild do RmlUi; o FreeType continua linkado e disponível
//        independente desta macro ("flip suave", não um descarte).
//     0  o motor de fonte default do RmlUi, apoiado em FreeType, é usado, inalterado (só
//        setado quando um consumidor configura explicitamente -DGLINTFX_OWN_FONT_ENGINE=OFF).
#cmakedefine01 GLINTFX_OWN_FONT_ENGINE

// EN: 1  (default) when the i18n module (ADR-0015 module "i18n", framework-2D slice i18n-1) is
//        compiled in: glintfx::I18n is available (glintfx/i18n.hpp). Depends on `core` only --
//        no GL, no window, no RmlUi type -- so it costs nothing to leave ON; OFF genuinely
//        removes the translation-unit and its symbols (ADR-0015 (a): flag OFF removes code, not
//        just a no-op stub), the same "living embryo" pattern GLINTFX_MODULE_WINDOW already
//        proves for a module built this cheaply outside phase A0.
//     0  glintfx::I18n is not compiled in; #include <glintfx/i18n.hpp> is skipped by the
//        umbrella header glintfx.hpp.
// PT: 1  (padrão) quando o módulo i18n (módulo "i18n" da ADR-0015, fatia framework-2D i18n-1)
//        é compilado: glintfx::I18n está disponível (glintfx/i18n.hpp). Depende só de `core` --
//        zero GL, zero janela, zero tipo do RmlUi -- então não custa nada deixar ON; OFF remove
//        de verdade a unidade de tradução e os símbolos dela (ADR-0015 (a): flag OFF remove
//        código, não é só um stub no-op), o mesmo padrão "embrião vivo" que GLINTFX_MODULE_WINDOW
//        já prova pra um módulo construído tão barato fora da fase A0.
//     0  glintfx::I18n não é compilado; #include <glintfx/i18n.hpp> é pulado pelo header
//        guarda-chuva glintfx.hpp.
#cmakedefine01 GLINTFX_MODULE_I18N

// EN: 1  (default) when the audio module (ADR-0015 module "audio", framework-2D slice
//        A3-AUDIO) is compiled in: glintfx::Audio is available (glintfx/audio.hpp), backed by
//        the vendored miniaudio. Depends on `core` only -- no GL, no window, no RmlUi type --
//        same independence class as GLINTFX_MODULE_I18N above, so it costs nothing to leave
//        ON; OFF genuinely removes the translation-units and their symbols (ADR-0015 (a): flag
//        OFF removes code, not just a no-op stub).
//     0  glintfx::Audio is not compiled in; #include <glintfx/audio.hpp> is skipped by the
//        umbrella header glintfx.hpp.
// PT: 1  (padrão) quando o módulo audio (módulo "audio" da ADR-0015, fatia framework-2D
//        A3-AUDIO) é compilado: glintfx::Audio está disponível (glintfx/audio.hpp), apoiado no
//        miniaudio vendorizado. Depende só de `core` -- zero GL, zero janela, zero tipo do
//        RmlUi -- mesma classe de independência do GLINTFX_MODULE_I18N acima, então não custa
//        nada deixar ON; OFF remove de verdade as unidades de tradução e os símbolos delas
//        (ADR-0015 (a): flag OFF remove código, não é só um stub no-op).
//     0  glintfx::Audio não é compilado; #include <glintfx/audio.hpp> é pulado pelo header
//        guarda-chuva glintfx.hpp.
#cmakedefine01 GLINTFX_MODULE_AUDIO

// EN: 1  (default on Linux; forced 0 elsewhere -- see CMakeLists.txt's platform gate) when the
//        gamepad module (ADR-0015 (b)/ADR-0016 module "gamepad", framework-2D slice A2-GAMEPAD)
//        is compiled in: glintfx::Gamepads is available (glintfx/gamepad.hpp), backed by raw
//        evdev (no libevdev/libudev/SDL dependency). Depends on `core` only -- no GL, no window,
//        no RmlUi type -- same independence class as GLINTFX_MODULE_I18N/AUDIO above. UNLIKE
//        those two, this module is Linux-only BY NATURE (evdev is a Linux kernel interface, not a
//        portable one), so the CMake option forces this to 0 on any non-Linux
//        CMAKE_SYSTEM_NAME -- there is no cross-platform fallback to compile instead.
//     0  glintfx::Gamepads is not compiled in; #include <glintfx/gamepad.hpp> is skipped by the
//        umbrella header glintfx.hpp (and #errors if included directly -- see gamepad.hpp's own
//        guard).
// PT: 1  (padrão no Linux; forçado 0 em qualquer outro lugar -- ver o gate de plataforma do
//        CMakeLists.txt) quando o módulo gamepad (módulo "gamepad" da ADR-0015 (b)/ADR-0016,
//        fatia framework-2D A2-GAMEPAD) é compilado: glintfx::Gamepads está disponível
//        (glintfx/gamepad.hpp), apoiado em evdev cru (sem dependência de libevdev/libudev/SDL).
//        Depende só de `core` -- zero GL, zero janela, zero tipo do RmlUi -- mesma classe de
//        independência do GLINTFX_MODULE_I18N/AUDIO acima. DIFERENTE desses dois, este módulo é
//        Linux-only POR NATUREZA (evdev é uma interface do kernel Linux, não portável), então a
//        option do CMake força isto pra 0 em qualquer CMAKE_SYSTEM_NAME não-Linux -- não há
//        fallback cross-platform pra compilar no lugar.
//     0  glintfx::Gamepads não é compilado; #include <glintfx/gamepad.hpp> é pulado pelo header
//        guarda-chuva glintfx.hpp (e dá #error se incluído diretamente -- ver a própria guarda do
//        gamepad.hpp).
#cmakedefine01 GLINTFX_MODULE_GAMEPAD

// EN: 1  (default, FX-CARVE-1) when the glintfx-AUTHORED shader fx module is compiled in: the
//        "glintfx-tint"/"glintfx-ripple" GLSL programs + their CompileShader/RenderShader/
//        ReleaseShader dispatch + the backdrop-capture machinery (src/fx/effects_gl3.cpp) and
//        the 3 decorator TUs (polygon/image-tint/ripple) are all present. Used internally by
//        render_gl3.cpp's Gl3RenderInterface constructor to gate the one call site that
//        constructs its `fx_` seam member (`CreateGl3FxHook()`, src/fx_hook.hpp) -- never
//        referenced from a public glintfx header, since this is a build-composition detail, not
//        an API surface consumers branch on.
//     0  the fx module is not compiled in: `decorator: polygon(...)`/`image-tint(...)`/
//        `ripple(...)` in RCSS are unrecognised and ignored by RmlUi (fail-high) -- RmlUi's own
//        upstream filter/gradient shaders (glow/box-shadow/drop-shadow/blur/backdrop-blur/mask/
//        gradients) are UNAFFECTED (see GLINTFX_MODULE_FX's own CMakeLists.txt doc string for
//        the honest boundary this flag stops at).
// PT: 1  (padrão, FX-CARVE-1) quando o módulo de shader fx AUTORAL da glintfx é compilado: os
//        programas GLSL "glintfx-tint"/"glintfx-ripple" + o despacho deles de CompileShader/
//        RenderShader/ReleaseShader + a maquinaria de captura de backdrop
//        (src/fx/effects_gl3.cpp) e as 3 TUs de decorator (polygon/image-tint/ripple) estão
//        todos presentes. Usado internamente pelo construtor de Gl3RenderInterface de
//        render_gl3.cpp pra gatear o único call site que constrói o membro de costura `fx_`
//        (`CreateGl3FxHook()`, src/fx_hook.hpp) -- nunca referenciado de um header público da
//        glintfx, já que isto é um detalhe de composição de build, não uma superfície de API
//        que consumidores ramificam.
//     0  o módulo fx não é compilado: `decorator: polygon(...)`/`image-tint(...)`/
//        `ripple(...)` no RCSS ficam não-reconhecidos e são ignorados pelo RmlUi (fail-high) --
//        os próprios shaders upstream de filtro/gradiente do RmlUi (glow/box-shadow/
//        drop-shadow/blur/backdrop-blur/mask/gradientes) NÃO são afetados (ver a própria doc
//        string de GLINTFX_MODULE_FX no CMakeLists.txt pra fronteira honesta onde esta flag
//        para).
#cmakedefine01 GLINTFX_MODULE_FX

// EN: Library version string ("MAJOR.MINOR.PATCH"), injected from the CMake project()
//     VERSION at configure time. Single source of truth -- see CMakeLists.txt.
// PT: String de versão da lib ("MAJOR.MINOR.PATCH"), injetada do VERSION do project()
//     do CMake em tempo de configure. Fonte única -- ver CMakeLists.txt.
#define GLINTFX_VERSION "@PROJECT_VERSION@"
