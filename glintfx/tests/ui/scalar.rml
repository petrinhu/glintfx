<!-- SPDX-License-Identifier: MPL-2.0 -->
<!--
  EN: Scalar data-model test document (T2, v0.2.3).
      Binds to the "hud" data model; exposes two scalar variables:
        {{label}}  — string, initially empty; becomes "HELLO HP 99" after set_string().
        {{hp}}     — number (double), initially 0 (renders "0"); becomes 99 after set_number().
      Font path "tests/assets/OpenSans-Regular.ttf" is relative to the test process CWD
      (CMAKE_BINARY_DIR = build/); WORKING_DIRECTORY in CMakeLists is set accordingly.
      The showcase CMake block copies demos/showcase/assets/ to build/tests/assets/, so the
      font is available when GLINTFX_BACKEND_GLFW=ON (same block as this test).
      Dark background + large font maximises the signal-to-noise ratio for the pixel
      statistics used in data_model_scalar.cpp: bright_B >> bright_A, bright_C > bright_B.
  PT: Documento de teste do data-model escalar (T2, v0.2.3).
      Liga ao data model "hud"; expõe duas variáveis escalares:
        {{label}}  — string, inicialmente vazia; vira "HELLO HP 99" após set_string().
        {{hp}}     — número (double), inicialmente 0 (renderiza "0"); vira 99 após set_number().
      O caminho da fonte "tests/assets/OpenSans-Regular.ttf" é relativo ao CWD do processo
      de teste (CMAKE_BINARY_DIR = build/); WORKING_DIRECTORY no CMakeLists é definido assim.
      O bloco CMake do showcase copia demos/showcase/assets/ para build/tests/assets/, então
      a fonte está disponível com GLINTFX_BACKEND_GLFW=ON (mesmo bloco deste teste).
      Fundo escuro + fonte grande maximiza a razão sinal/ruído para as estatísticas de pixel
      usadas em data_model_scalar.cpp: bright_B >> bright_A, bright_C > bright_B.
-->
<rml>
<head>
  <style>
    /* EN: Load OpenSans from the test asset dir (resolved from process CWD = build/).
       PT: Carrega OpenSans do diretório de asset de teste (resolvido do CWD = build/). */
    @font-face { font-family: "Sans"; src: "tests/assets/OpenSans-Regular.ttf"; }

    /* EN: Full-viewport dark body; large bright text ensures pixel count changes are detectable.
       PT: Body escuro full-viewport; texto claro grande garante que mudanças na contagem de
           pixels sejam detectáveis. */
    body {
      background: #111111;
      color: #eeeeee;
      font-family: "Sans";
      font-size: 40px;
      margin: 8px;
      display: block;
      width: 100%;
      height: 100%;
    }

    /* EN: Block display so {{label}} and {{hp}} stack vertically on separate lines.
       PT: Display block para que {{label}} e {{hp}} empilhem verticalmente em linhas separadas. */
    p { display: block; }
  </style>
  <title>glintfx scalar data-model test</title>
</head>
<body data-model="hud">
  <p id="label">{{label}}</p>
  <p id="hp">{{hp}}</p>
</body>
</rml>
